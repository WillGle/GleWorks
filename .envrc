# Load Nix flake environment
use flake

# Project-specific environment variables
export NODE_ENV=development
export VITE_PORT=5173
export VITE_API_URL=http://localhost:3000

# Docker configuration
export COMPOSE_PROJECT_NAME=gitwork
export DOCKER_BUILDKIT=1

# Jenkins integration (for local testing)
export JENKINS_URL=http://localhost:8080
export SONAR_HOST_URL=http://localhost:9000

# Tailscale network (for demo)
export DEMO_NETWORK=jenkins-network

# Enable logging
export DEBUG=vite:*

# Git hooks
export HUSKY_SKIP_INSTALL=0

# Load local .env if exists (for secrets)
if [ -f .env.local ]; then
  dotenv .env.local
fi

echo "Project environment loaded!"
